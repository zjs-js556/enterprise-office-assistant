# ============================================
# 企业办公助手 — 生产环境变量模板
# 复制此文件为 /opt/office-assistant/.env 并填写真实值
# ============================================

# Flask
FLASK_ENV=production
APP_PORT=8000
SECRET_KEY=

# JWT
JWT_SECRET_KEY=
JWT_EXPIRES_HOURS=2

# MySQL
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=office_assistant
MYSQL_USER=office_user
MYSQL_PASSWORD=

# 数据库连接（容器内使用，office-mysql 是 docker-compose 中的服务名）
DATABASE_URL=mysql+pymysql://office_user:PASSWORD@office-mysql:3306/office_assistant

# CORS（前端允许的源，JSON 数组格式）
CORS_ORIGINS=["http://localhost:19006","http://localhost:8081"]

# Gitee Webhook
WEBHOOK_SECRET=
WEBHOOK_PORT=9000
